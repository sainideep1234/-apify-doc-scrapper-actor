# Environment Variables for Documentation Scraper
# Copy this file to .env and fill in your actual credentials

# Weaviate Configuration
# Get from: https://console.weaviate.cloud/
# Format: your-cluster-name.weaviate.network (without https://)
WEAVIATE_HOST=your-cluster-name.weaviate.network
WEAVIATE_API_KEY=your-weaviate-api-key

# OpenAI Configuration
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key

# Optional: Weaviate Class Name (default: Documentation)
# WEAVIATE_CLASS=Documentation
